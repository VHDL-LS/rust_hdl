---
IfStatement
  IfStatementPreamble
    Keyword(If)
    BinaryExpression
      NameExpression
        Name
          Identifier 'cond'
      EQ
      NameExpression
        Name
          Identifier 'true'
    Keyword(Then)
  SequentialStatements
    ProcedureCallStatement
      NameTarget
        Name
          Identifier 'foo'
          RawTokens
            LeftPar
            AbstractLiteral '1'
            Comma
            AbstractLiteral '2'
            RightPar
      SemiColon
    SimpleVariableAssignment
      NameTarget
        Name
          Identifier 'x'
      ColonEq
      LiteralExpression
        AbstractLiteral '1'
      SemiColon
  IfStatementEpilogue
    Keyword(End)
    Keyword(If)
    SemiColon
